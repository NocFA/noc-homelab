        <Duration>P9999D</Duration>
        <StopAtDurationEnd>true</StopAtDurationEnd>
      </Repetition>
    </TimeTrigger>
  </Triggers>
  <Actions Context="Author">
    <Exec>
      <Command>powershell.exe</Command>
      <Arguments>-ExecutionPolicy Bypass -WindowStyle Hidden -File C:\Users\noc\homelab\gatus\healthcheck.ps1</Arguments>
      <WorkingDirectory>C:\Users\noc\homelab\gatus</WorkingDirectory>
    </Exec>
