          "port": 9999,
          "description": "Real-Debrid WebDAV",
          "url": "http://noc-winlocal:9999",
          "manager": "scheduled-task",
          "task_name": "Homelab-Zurg",
          "process_name": "zurg"
        },
        "rclone": {
          "name": "Rclone Mount",
          "port": null,
          "description": "Zurg WebDAV mount (Z: drive)",
          "url": null,
          "manager": "scheduled-task",
          "task_name": "Homelab-RcloneMount",
          "process_name": "rclone"
        },
        "parsec": {
          "name": "Parsec",
          "port": null,
          "description": "Remote desktop gaming",
          "url": null,
