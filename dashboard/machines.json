      "services": {
        "emby": {
          "name": "Emby",
          "port": 8096,
          "description": "Media streaming server",
          "url": "http://noc-winlocal:8096",
          "manager": "process",
          "process_name": "EmbyServer",
          "start_cmd": "Start-Process 'C:\\Users\\noc\\AppData\\Roaming\\Emby-Server\\system\\EmbyServer.exe' -ArgumentList '-service'",
          "stop_cmd": "Stop-Process -Name EmbyServer,embytray -Force -ErrorAction SilentlyContinue"
        },
        "sunshine": {
          "name": "Sunshine",
          "port": 47990,
