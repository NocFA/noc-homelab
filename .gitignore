# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.venv/
venv/

# Logs
*.log
*.log.*
logs/

# Runtime data
*.pid
*.seed
*.pid.lock
.alert_history.json

# Databases
*.db
*.sqlite
*.sqlite3
database/
db/

# Caches
cache/
.cache/
*.cache

# Backups
backup/
*.backup
*.bak

# Sensitive config data
configs/nzbhydra2/database/
configs/nzbhydra2/cache/
configs/nzbhydra2/logs/
configs/nzbhydra2/backup/

# Secrets (be careful!)
*secret*
*password*
*.key
*.pem
*.p12
certs/
CREDENTIALS.txt
*CREDENTIALS*

# macOS
.DS_Store
.AppleDouble
.LSOverride

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Temp files
*.tmp
temp/
tmp/
# Separate projects (have their own repos)
061tech/

# SOPS decrypted files (plaintext secrets, never commit)
*.dec

# Docker service runtime data (incl. timestamped migration/backup snapshots)
services/*/data/
services/*/data.*/
services/*/db/


# Gatus config (contains Discord webhook secrets)
services/gatus/config.yaml
services/gatus/config.yml
services/gatus/config-winlocal.yaml

# Zurg binary and runtime data (downloaded/generated, not committed)
services/zurg/zurg.exe
linux/services/zurg/zurg
linux/services/zurg/data/
linux/services/zurg/logs/

# Agent config (machine-specific)
agent/config.yaml

# Media symlinks directory (runtime)
media/

# AI/development tooling
.beads/
beads.db*
.claude/
AGENTS.md
CLAUDE.md
GEMINI.md
noc-homelab-beads/

# Vendored binaries (build artifacts, not source)
linux/services/rathole/rathole

# Matrix — plaintext inventory (secrets), only SOPS-encrypted vars committed.
# Allow the synapse log config template through since it has no secrets and
# the ansible var matrix_synapse_template_synapse_log references it directly.
# Use `**` so the negation below can re-include specific files.
services/matrix/inventory/**
!services/matrix/inventory/host_vars/
!services/matrix/inventory/host_vars/matrix.nocfa.net/
!services/matrix/inventory/host_vars/matrix.nocfa.net/synapse.log.config.j2

# Dolt SQL server runtime directories and config
beads/
beads_mdsf-crew/
config.yaml
# Exception: crowdsec firewall-bouncer config — sensitive (api_key) but
# tracked in repo (SOPS-encrypted on commit by pre-commit hook).
!linux/services/crowdsec/config.yaml

# TeamSpeak server-generated backup files
configs/teamspeak/backups/

# Internal operational docs (not for public repo)
docs/migration.md

# Branch-local scratch, planning, and handoff notes.
# Ephemeral docs generated during a branch's lifecycle (HANDOFF.md,
# TRACKING.md, session checkpoints, etc.). These MUST NOT ship to the
# public repo — if anything here deserves to persist, promote it
# explicitly into docs/ or noc-homelab-beads/memory/ first.
# Named dirs cover current/past branches; generic .scratch/ + scratch/
# catch future ones by convention.
.homelab-lockdown/
.scratch/
scratch/

# Re-include .env.example placeholder files so fork/clone knows what to
# configure. Global gitignore blocks `.env.*`; negate here for examples only.
!*.env.example
!**/.env.example
