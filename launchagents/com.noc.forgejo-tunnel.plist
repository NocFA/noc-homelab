<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.noc.forgejo-tunnel</string>

    <key>ProgramArguments</key>
    <array>
        <string>/Users/noc/dev/rathole/rathole</string>
        <string>--client</string>
        <string>/Users/noc/dev/rathole/client-forgejo.toml</string>
