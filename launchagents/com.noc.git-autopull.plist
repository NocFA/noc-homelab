<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.noc.git-autopull</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>-l</string>
        <string>-c</string>
        <string>/Users/noc/noc-homelab/scripts/git-autopull.sh</string>
    </array>

    <key>StartInterval</key>
    <integer>300</integer>

    <key>RunAtLoad</key>
    <true/>

    <key>StandardOutPath</key>
    <string>/Users/noc/noc-homelab/logs/git-autopull.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/noc/noc-homelab/logs/git-autopull.log</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/opt/homebrew/bin:/opt/homebrew/sbin:/usr/local/bin:/usr/bin:/bin:/Users/noc/.local/bin</string>
        <key>SOPS_AGE_KEY_FILE</key>
        <string>/Users/noc/noc-homelab/noc-homelab-beads/homelab.agekey</string>
    </dict>
</dict>
</plist>
