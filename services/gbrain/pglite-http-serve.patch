---NEW FILE: src/core/pglite-sql-adapter.ts---
/**
 * Adapter that bridges PGLite's query interface to postgres.js tagged template
 * syntax. Enables serve-http.ts (which uses postgres.js tagged templates for
 * OAuth, admin dashboard, and request logging) to work with PGLite engines.
 *
 * Supports:
 * - Basic tagged template queries: sql`SELECT * FROM t WHERE id = ${id}`
 * - Fragment composition: sql`... ${sql`AND col = ${val}`} ...`
 * - Empty fragments: sql``
 */

import type { BrainEngine } from '../core/engine.ts';
import type { SqlQuery } from '../core/oauth-provider.ts';

const FRAGMENT_MARKER = Symbol.for('pglite-sql-fragment');

interface SqlFragment {
  [key: symbol]: true;
  text: string;
  params: unknown[];
  then: (resolve: (value: unknown) => void, reject: (reason: unknown) => void) => void;
}

export function createPgliteSqlProxy(engine: BrainEngine): SqlQuery {
  function sql(strings: TemplateStringsArray, ...values: unknown[]): SqlFragment {
    let text = '';
    const params: unknown[] = [];
    let paramIdx = 1;

    for (let i = 0; i < strings.length; i++) {
      text += strings[i];
      if (i < values.length) {
        const val = values[i] as any;
        if (val && val[FRAGMENT_MARKER]) {
          const fragText = val.text as string;
          const fragParams = val.params as unknown[];
          // Renumber fragment params ($1, $2, ...) to current offset.
          // Process highest-numbered first to avoid $1 matching inside $10.
          let renumbered = fragText;
          for (let j = fragParams.length; j >= 1; j--) {
            renumbered = renumbered.replace(
              new RegExp(`\\$${j}(?!\\d)`, 'g'),
              `$${paramIdx + j - 1}`,
            );
          }
          text += renumbered;
          params.push(...fragParams);
          paramIdx += fragParams.length;
        } else {
          text += `$${paramIdx}`;
          params.push(val);
          paramIdx++;
        }
      }
    }

    return {
      [FRAGMENT_MARKER]: true,
      text,
      params,
      then(resolve, reject) {
        engine.executeRaw(text, params).then(resolve, reject);
      },
    };
  }

  return sql as unknown as SqlQuery;
}
