# Real values live in .env (gitignored). Copy this file and fill in.
# Credentials are generated on the central LAPI host (noc-tux) via:
#   sudo cscli machines add <machine-name>-mac --auto -f -
# and printed once — store them here immediately.
#
# install-native.sh renders these into
# /opt/homebrew/etc/crowdsec/local_api_credentials.yaml (chmod 600). The
# native agent reads the local hostname from the OS, so no HOSTNAME var
# is needed here (unlike the retired Docker path).

LOCAL_API_URL=http://noc-tux:8150
AGENT_USERNAME=CHANGE_ME_MACHINE_NAME
AGENT_PASSWORD=CHANGE_ME_64_CHAR_PASSWORD
