# cf-crowdsec-sync env. Install to /etc/cf-crowdsec-sync.env, chmod 0600.
#
# This file is NOT auto-decrypted by the SOPS post-merge hook (it lives
# outside the repo on disk). Sync the repo template to /etc and edit there
# whenever rotating the token.

# Cloudflare API token with: Zone -> Zone WAF -> Edit on looney.eu.
CF_API_TOKEN=CHANGE_ME

# looney.eu zone ID
CF_ZONE_ID=44ddcfd51aa8edef2dea3e3a64a08a58

# http_request_firewall_custom ruleset entrypoint id (looney.eu zone)
CF_RULESET_ID=94b71e660ff44a4bb0dfdbeb4c24dc6b

# The "lovelang: crowdsec ban (synced)" rule id within that ruleset
CF_RULE_ID=fe48d0653402416aa4b35ca65d4b9517

# Hostname guard inside the rule expression
CF_RULE_HOST=love.looney.eu

# Cap pushed to CF (expression is limited to ~4 KB on free tier)
MAX_IPS=200
