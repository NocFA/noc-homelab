# Copy to scan.env next to scan.sh (or /etc/hl-scan.env) and fill in.
# `scan.env` is gitignored / SOPS-encrypted on commit.

# Space-separated lists
TARGETS_HTTP="https://nocfa.net https://auth.nocfa.net https://element.nocfa.net https://api.nocfa.net https://matrix.nocfa.net https://dev.nocfa.net https://play.nocfa.net https://games.nocfa.net https://ie1.nocfa.net https://looney.eu"
TARGETS_SSL="matrix.nocfa.net:443 auth.nocfa.net:443 nocfa.net:443 looney.eu:443"
TARGETS_SSH="noc-baguette:22"

# Alerting
DISCORD_WEBHOOK=https://discord.com/api/webhooks/CHANGE_ME_ID/CHANGE_ME_TOKEN

# Severities to include — nuclei `-severity` flag
NUCLEI_SEV="medium,high,critical"

# Working dir (defaults fine)
SCAN_DIR=/var/lib/hl-scan
