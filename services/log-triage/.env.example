# Real values live in .env (gitignored / SOPS-encrypted on commit).

MLX_URL=http://localhost:8181/v1/chat/completions
MLX_MODEL=mlx-community/gemma-3-12b-it-4bit
# Per-request timeout for the MLX completion call. 60s was too tight for the
# fat Loki-context prompts produced by http-probing alerts on M4 16GB; 180s
# gives reliable headroom while the in-app prompt caps keep the typical case
# well below it. See noc-homelab-ynu0.
MLX_REQUEST_TIMEOUT_SECONDS=180
LOKI_URL=http://noc-tux:3100
DISCORD_WEBHOOK=https://discord.com/api/webhooks/CHANGE_ME_ID/CHANGE_ME_TOKEN
AUTH_TOKEN=CHANGE_ME_32_HEX_CHARS
LISTEN_PORT=8182
LISTEN_HOST=0.0.0.0
DEDUPE_WINDOW_SECONDS=600
MAX_PER_HOUR=30
LOG_LEVEL=INFO
