# Real values live in .env (gitignored / SOPS-encrypted on commit).
# Copy this file to .env and replace placeholders.

# Grafana admin password. Generate with: openssl rand -hex 16
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_32_HEX_CHARS

# Discord webhook URL for Grafana anomaly alerts (WAN spike, CPU pegged,
# mem pressure, disk near-full, Netdata scrape down). Leave empty to
# disable alerting silently — dashboards still work.
#   Discord: Server Settings → Integrations → Webhooks → New Webhook
GRAFANA_DISCORD_WEBHOOK=
