---
import Page from '../layouts/Page.astro';
import {
  services,
  packages,
  quickLinks,
  pricing,
  seoKeywords
} from '../data/config';

// Destructure services for easier template access
const { hardware: hardwareServices, upgrades: componentUpgrades, builds: buildServices, software: softwareServices, data: dataServices, remote: remoteServices } = services;
---

<Page title="Services & Pricing" description={`Computer repair prices in Limerick. Fix slow PC, virus removal, laptop won't turn on, data recovery, screen repair. SSD upgrades, RAM, GPU (${seoKeywords.gpu}). Custom gaming PC builds. No hidden fees - see all prices upfront.`}>

  <!-- Page Header -->
  <section class="page-header">
    <div class="container">
      <h1>Services & Pricing</h1>
      <p class="page-intro">Transparent pricing. No hidden fees. If I can't fix it, you don't pay.</p>
    </div>
  </section>

  <!-- Not Sure? Callout -->
  <section class="section callout-section">
    <div class="container">
      <div class="callout">
        <div class="callout-content">
          <h2>Not sure what's wrong?</h2>
          <p>Don't worry - most people aren't. Book a <strong>€20 video diagnosis</strong> and I'll help figure out the problem and give you an honest quote. If you go ahead with the repair, the €20 comes off your bill.</p>
        </div>
        <a href="/book" class="btn btn-primary">Book Video Diagnosis</a>
      </div>
    </div>
  </section>

  <!-- Sticky Quick Jump -->
  <nav class="quick-jump-nav" id="quick-jump-nav" aria-label="Jump to section">
    <div class="container">
      <div class="quick-jump-links">
        {quickLinks.map(link => (
          <a href={link.anchor} class="quick-jump-link">{link.label}</a>
        ))}
      </div>
    </div>
    <button
      class="quick-jump-dismiss"
      id="quick-jump-dismiss"
      type="button"
      aria-label="Hide navigation"
      title="Hide navigation"
    >
      <svg width="20" height="6" viewBox="0 0 20 6" fill="none" aria-hidden="true">
        <path d="M4 1.5H16M4 4.5H16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
    </button>
  </nav>

  <!-- Show button (appears when nav is hidden) -->
  <button
    class="quick-jump-show"
    id="quick-jump-show"
    type="button"
    aria-label="Show navigation"
    title="Show jump links"
  >
    <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
      <path d="M2 4H14M2 8H14M2 12H14" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
    </svg>
  </button>

  <!-- Hardware Repairs -->
  <section class="section" id="hardware">
    <div class="container">
      <h2>Hardware Repairs</h2>
      <p class="section-desc">For when it won't turn on, makes strange noises, or something's physically broken.</p>
      <div class="table-wrapper">
        <table>
          <thead>
            <tr>
              <th>Service</th>
              <th>Description</th>
              <th>Price</th>
              <th>Turnaround*</th>
            </tr>
          </thead>
          <tbody>
            {hardwareServices.map(s => (
              <tr class={s.comingSoon ? 'coming-soon' : ''}>
                <td><strong>{s.service}</strong></td>
                <td>{s.desc}</td>
                <td class="price-cell">{s.price}</td>
                <td>{s.time}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="table-note">* Turnaround times are from when I receive your device - add courier time on top. Parts costs are additional and quoted before any work begins.</p>
    </div>
  </section>

  <!-- Component Upgrades -->
  <section class="section section--alt" id="upgrades">
    <div class="container">
      <h2>Component Upgrades</h2>
      <p class="section-desc">Upgrade individual parts to boost performance. Works for laptops and desktop PCs - I'll check compatibility before ordering anything.</p>
      <div class="table-wrapper">
        <table>
          <thead>
            <tr>
              <th>Service</th>
              <th>Description</th>
              <th>Price</th>
              <th>Turnaround*</th>
            </tr>
          </thead>
          <tbody>
            {componentUpgrades.map(s => (
              <tr>
                <td><strong>{s.service}</strong></td>
                <td>{s.desc}</td>
                <td class="price-cell">{s.price}</td>
                <td>{s.time}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="table-note">An SSD upgrade is the single best thing you can do for an old computer. It's like night and day.</p>
    </div>
  </section>

  <!-- Build Services -->
  <section class="section" id="builds">
    <div class="container">
      <h2>Build & Assembly Services</h2>
      <p class="section-desc">Major work - new builds, case swaps, or complete overhauls. For when you want serious changes.</p>
      <div class="table-wrapper">
        <table>
          <thead>
            <tr>
              <th>Service</th>
              <th>Description</th>
              <th>Price</th>
              <th>Turnaround*</th>
            </tr>
          </thead>
          <tbody>
            {buildServices.map(s => (
              <tr>
                <td><strong>{s.service}</strong></td>
                <td>{s.desc}</td>
                <td class="price-cell">{s.price}</td>
                <td>{s.time}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="table-note">Custom builds: you can supply parts, or I can help spec a system to your budget and needs.</p>
    </div>
  </section>

  <!-- Software Services -->
  <section class="section section--alt" id="software">
    <div class="container">
      <h2>Software & Security</h2>
      <p class="section-desc">For viruses, pop-ups, slow performance, or when you just want a fresh start.</p>
      <div class="table-wrapper">
        <table>
          <thead>
            <tr>
              <th>Service</th>
              <th>Description</th>
              <th>Price</th>
              <th>Turnaround*</th>
            </tr>
          </thead>
          <tbody>
            {softwareServices.map(s => (
              <tr>
                <td><strong>{s.service}</strong></td>
                <td>{s.desc}</td>
                <td class="price-cell">{s.price}</td>
                <td>{s.time}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Data Services -->
  <section class="section" id="data">
    <div class="container">
      <h2>Data Recovery & Backup</h2>
      <p class="section-desc">For when you've lost important files or want to make sure you never do.</p>
      <div class="table-wrapper">
        <table>
          <thead>
            <tr>
              <th>Service</th>
              <th>Description</th>
              <th>Price</th>
              <th>Turnaround*</th>
            </tr>
          </thead>
          <tbody>
            {dataServices.map(s => (
              <tr>
                <td><strong>{s.service}</strong></td>
                <td>{s.desc}</td>
                <td class="price-cell">{s.price}</td>
                <td>{s.time}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="table-note">Data recovery success depends on the drive's condition. I'll always be honest about the chances.</p>
    </div>
  </section>

  <!-- Remote Services -->
  <section class="section section--alt" id="remote">
    <div class="container">
      <h2>Remote Services</h2>
      <p class="section-desc">Some things don't need a courier. I can help over the internet.</p>
      <div class="table-wrapper">
        <table>
          <thead>
            <tr>
              <th>Service</th>
              <th>Description</th>
              <th>Price</th>
              <th>Note</th>
            </tr>
          </thead>
          <tbody>
            {remoteServices.map(s => (
              <tr>
                <td><strong>{s.service}</strong></td>
                <td>{s.desc}</td>
                <td class="price-cell">{s.price}</td>
                <td class="note-cell">{s.note}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Packages -->
  <section class="section" id="packages">
    <div class="container">
      <h2>Service Packages</h2>
      <p class="section-desc">Bundle your repair with extras and save.</p>
      <div class="packages-grid">
        {packages.map(pkg => (
          <div class={`package-card ${pkg.popular ? 'package-card--popular' : ''}`}>
            {pkg.popular && <span class="popular-badge">Most Popular</span>}
            <h3>{pkg.name}</h3>
            <p class="package-desc">{pkg.desc}</p>
            <ul class="package-includes">
              {pkg.includes.map(item => (
                <li>{item}</li>
              ))}
            </ul>
            <span class="package-price">{pkg.price}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Courier Info -->
  <section class="section">
    <div class="container courier-info">
      <h2>Courier Collection & Delivery</h2>
      <p>Courier costs are separate from repair costs. Prices depend on device size and location:</p>

      <h3>Laptops</h3>
      <ul>
        <li><strong>Limerick City:</strong> €30-40 total (collection + return)</li>
        <li><strong>County Limerick:</strong> €40-50 total</li>
      </ul>

      <h3>Desktop PCs</h3>
      <ul>
        <li><strong>Limerick City:</strong> €50-60 total (heavier, need careful handling)</li>
        <li><strong>County Limerick:</strong> €60-70 total</li>
      </ul>

      <p class="courier-note">Exact costs quoted when you book. You can also arrange your own courier, or drop off/collect in person by arrangement - just ask.</p>
    </div>
  </section>

  <!-- CTA -->
  <section class="section section--alt">
    <div class="container cta-section">
      <h2>Ready to get your computer fixed?</h2>
      <p>Book online or get in touch. I'll reply within 24 hours.</p>
      <div class="cta-buttons">
        <a href="/book" class="btn btn-primary btn-lg">Book a Repair</a>
        <a href="/contact" class="btn btn-secondary btn-lg">Contact Me</a>
      </div>
    </div>
  </section>

</Page>

<style>
  /* Page Header */
  .page-header {
    padding: var(--space-2xl) 0 var(--space-xl);
    text-align: center;
  }

  .page-header h1 {
    margin-bottom: var(--space-sm);
  }

  .page-intro {
    font-size: var(--text-lg);
    color: var(--text-secondary);
    max-width: 500px;
    margin: 0 auto;
  }

  /* Callout */
  .callout-section {
    padding-top: 0;
  }

  .callout {
    background: var(--accent-subtle);
    border: 1px solid var(--accent);
    border-radius: 6px;
    padding: var(--space-xl);
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
    align-items: flex-start;
  }

  @media (min-width: 768px) {
    .callout {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
    }
  }

  .callout h2 {
    font-size: var(--text-xl);
    margin-bottom: var(--space-sm);
    color: var(--accent);
  }

  .callout p {
    margin: 0;
    color: var(--text-primary);
  }

  .callout .btn {
    flex-shrink: 0;
  }

  .quick-jump-nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--bg-primary);
    border-bottom: 1px solid var(--border);
    padding: var(--space-md) 0;
    transition: transform 150ms ease, box-shadow 150ms ease, opacity 150ms ease;
  }

  .quick-jump-nav.hidden {
    transform: translateY(-100%);
    opacity: 0;
    pointer-events: none;
  }

  .quick-jump-nav.scrolled {
    box-shadow: var(--shadow-md);
  }

  .quick-jump-links {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-sm);
  }

  .quick-jump-link {
    display: inline-block;
    padding: 0.5rem 0.875rem;
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: 4px;
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--text-primary);
    text-decoration: none;
    white-space: nowrap;
    position: relative;
    top: 0;
    box-shadow: 2px 2px 0 var(--border);
    transition: top 100ms ease, box-shadow 100ms ease, border-color 100ms ease, color 100ms ease;
  }

  .quick-jump-link:hover {
    top: 1px;
    box-shadow: 1px 1px 0 var(--accent);
    border-color: var(--accent);
    color: var(--accent);
  }

  .quick-jump-link:active {
    top: 2px;
    box-shadow: 0 0 0 var(--accent);
  }

  .quick-jump-dismiss {
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%) translateY(100%);
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 10px;
    padding: 0;
    background: var(--bg-primary);
    border: none;
    border-left: 1px solid var(--border);
    border-right: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    border-radius: 0 0 4px 4px;
    color: var(--text-muted);
    cursor: pointer;
    opacity: 0;
    pointer-events: none;
    transition: opacity 150ms ease, color 100ms ease, height 100ms ease;
  }

  .quick-jump-nav.scrolled .quick-jump-dismiss {
    opacity: 0.6;
    pointer-events: auto;
  }

  .quick-jump-dismiss:hover {
    opacity: 1;
    color: var(--text-primary);
    height: 12px;
  }

  .quick-jump-dismiss:active {
    color: var(--accent);
  }

  .quick-jump-show {
    position: fixed;
    top: var(--space-md);
    right: var(--space-md);
    z-index: 99;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    padding: 0;
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: 6px;
    color: var(--text-secondary);
    cursor: pointer;
    box-shadow: 2px 2px 0 var(--border);
    opacity: 0;
    transform: translateY(-8px);
    pointer-events: none;
    transition: opacity 150ms ease, transform 150ms ease, top 100ms ease, box-shadow 100ms ease;
  }

  .quick-jump-show.visible {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  .quick-jump-show:hover {
    top: calc(var(--space-md) + 1px);
    box-shadow: 1px 1px 0 var(--border);
    color: var(--text-primary);
  }

  @media (max-width: 640px) {
    .quick-jump-nav {
      padding: var(--space-sm) 0;
    }

    .quick-jump-nav .container {
      padding: 0;
      position: relative;
    }

    .quick-jump-nav .container::before,
    .quick-jump-nav .container::after {
      content: '';
      position: absolute;
      top: 0;
      bottom: 0;
      width: 32px;
      pointer-events: none;
      z-index: 1;
      transition: opacity 150ms ease;
    }

    .quick-jump-nav .container::before {
      left: 0;
      background: linear-gradient(to left, transparent, var(--bg-primary));
      opacity: 0;
    }

    .quick-jump-nav .container.scrolled-right::before {
      opacity: 1;
    }

    .quick-jump-nav .container::after {
      right: 0;
      background: linear-gradient(to right, transparent, var(--bg-primary));
      opacity: 1;
    }

    .quick-jump-nav .container.scrolled-end::after {
      opacity: 0;
    }

    .quick-jump-links {
      flex-wrap: nowrap;
      justify-content: flex-start;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      padding: var(--space-xs) var(--space-md);
      padding-right: 48px;
      gap: var(--space-sm);
    }

    .quick-jump-links::-webkit-scrollbar {
      display: none;
    }

    .quick-jump-link {
      padding: 0.5rem 0.875rem;
      font-size: var(--text-sm);
      box-shadow: 1px 1px 0 var(--border);
      flex-shrink: 0;
    }

    .quick-jump-link:hover {
      box-shadow: 0 0 0 var(--accent);
    }

    .quick-jump-show {
      top: var(--space-sm);
      right: var(--space-sm);
      width: 32px;
      height: 32px;
    }
  }

  /* Section styling */
  .section h2 {
    margin-bottom: var(--space-sm);
  }

  .section-desc {
    color: var(--text-secondary);
    margin-bottom: var(--space-xl);
    max-width: 600px;
  }

  /* Tables */
  .table-wrapper {
    overflow-x: auto;
    margin: 0 calc(-1 * var(--space-md));
    padding: 0 var(--space-md);
  }

  table {
    min-width: 600px;
  }

  .price-cell {
    font-family: var(--font-mono);
    color: var(--accent);
    font-weight: 500;
    white-space: nowrap;
  }

  .note-cell {
    font-size: var(--text-sm);
    color: var(--text-muted);
    font-style: italic;
  }

  .coming-soon td {
    color: var(--text-muted);
  }

  .coming-soon .price-cell {
    color: var(--text-muted);
  }

  .table-note {
    font-size: var(--text-sm);
    color: var(--text-muted);
    margin-top: var(--space-md);
    font-style: italic;
  }

  /* Packages */
  .packages-grid {
    display: grid;
    gap: var(--space-lg);
  }

  @media (min-width: 768px) {
    .packages-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .package-card {
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: var(--space-xl);
    position: relative;
    display: flex;
    flex-direction: column;
  }

  .package-card--popular {
    border-color: var(--accent);
  }

  .popular-badge {
    position: absolute;
    top: -0.75rem;
    left: 50%;
    transform: translateX(-50%);
    background: var(--accent);
    color: #1c1917;
    font-size: var(--text-xs);
    font-weight: 600;
    padding: var(--space-xs) var(--space-sm);
    border-radius: 4px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .package-card h3 {
    font-size: var(--text-xl);
    margin-bottom: var(--space-xs);
  }

  .package-desc {
    color: var(--text-secondary);
    font-size: var(--text-sm);
    margin-bottom: var(--space-md);
  }

  .package-includes {
    list-style: none;
    margin-bottom: var(--space-lg);
    flex-grow: 1;
  }

  .package-includes li {
    position: relative;
    padding-left: 1.5rem;
    margin-bottom: var(--space-xs);
    font-size: var(--text-sm);
  }

  .package-includes li::before {
    content: "✓";
    position: absolute;
    left: 0;
    color: var(--success);
    font-weight: bold;
  }

  .package-price {
    font-family: var(--font-mono);
    font-size: var(--text-lg);
    font-weight: 600;
    color: var(--accent);
    padding-top: var(--space-md);
    border-top: 1px solid var(--border);
  }

  /* Courier Info */
  .courier-info {
    max-width: 600px;
  }

  .courier-info h2 {
    margin-bottom: var(--space-md);
  }

  .courier-info ul {
    list-style: none;
    margin: var(--space-md) 0;
  }

  .courier-info li {
    margin-bottom: var(--space-sm);
  }

  .courier-info h3 {
    font-size: var(--text-base);
    margin-top: var(--space-lg);
    margin-bottom: var(--space-sm);
    color: var(--text-secondary);
  }

  .courier-note {
    font-size: var(--text-sm);
    color: var(--text-muted);
    font-style: italic;
    margin-top: var(--space-lg);
  }

  /* CTA */
  .cta-section {
    text-align: center;
    max-width: 500px;
  }

  .cta-section h2 {
    margin-bottom: var(--space-sm);
  }

  .cta-section p {
    color: var(--text-secondary);
    margin-bottom: var(--space-xl);
  }

  .cta-buttons {
    display: flex;
    gap: var(--space-md);
    justify-content: center;
    flex-wrap: wrap;
  }
</style>

<script>
  const nav = document.getElementById('quick-jump-nav');
  const dismissBtn = document.getElementById('quick-jump-dismiss');
  const showBtn = document.getElementById('quick-jump-show');

  let userDismissed = false;

  if (dismissBtn && showBtn && nav) {
    dismissBtn.addEventListener('click', () => {
      userDismissed = true;
      nav.classList.add('hidden');
      showBtn.classList.add('visible');
    });

    showBtn.addEventListener('click', () => {
      userDismissed = false;
      nav.classList.remove('hidden');
      showBtn.classList.remove('visible');
    });
  }

  if (nav) {
    const sentinel = document.createElement('div');
    sentinel.style.cssText = 'position:absolute;top:0;height:1px;width:100%;pointer-events:none;';
    nav.parentNode.insertBefore(sentinel, nav);

    const observer = new IntersectionObserver(
      ([entry]) => {
        const isSticky = !entry.isIntersecting;
        nav.classList.toggle('scrolled', isSticky);

        // Auto-restore when scrolled back to original position
        if (!isSticky && userDismissed) {
          userDismissed = false;
          nav.classList.remove('hidden');
          showBtn.classList.remove('visible');
        }
      },
      { threshold: 0 }
    );
    observer.observe(sentinel);
  }

  const linksContainer = document.querySelector('.quick-jump-links');
  const navContainer = nav?.querySelector('.container');

  if (linksContainer && navContainer) {
    const updateScrollFades = () => {
      const { scrollLeft, scrollWidth, clientWidth } = linksContainer;
      const scrolledRight = scrollLeft > 8;
      const scrolledEnd = scrollLeft >= scrollWidth - clientWidth - 8;

      navContainer.classList.toggle('scrolled-right', scrolledRight);
      navContainer.classList.toggle('scrolled-end', scrolledEnd);
    };

    linksContainer.addEventListener('scroll', updateScrollFades, { passive: true });
    updateScrollFades();
    window.addEventListener('resize', updateScrollFades, { passive: true });
  }
</script>
