---
import Page from '../layouts/Page.astro';
---

<Page title="Contact" description="Need computer help in Limerick? Contact 061 Tech - local PC and laptop repair service. Email, WhatsApp, or live chat. Quick replies, no call centres. Serving Limerick city and county.">

  <!-- Page Header -->
  <section class="page-header">
    <div class="container">
      <h1>Contact</h1>
      <p class="page-intro">Got a question? Get in touch. I reply within 24 hours.</p>
    </div>
  </section>

  <!-- Contact Options -->
  <section class="section">
    <div class="container">
      <div class="contact-grid">

        <div class="contact-card">
          <h2>Live Chat</h2>
          <p>Quick questions? Chat directly on the site.</p>
          <div class="contact-card-footer">
            <button type="button" class="btn btn-primary contact-btn chat-trigger">Start Chat</button>
            <span class="contact-note">Fastest response</span>
          </div>
        </div>

        <div class="contact-card contact-card--disabled">
          <h2>WhatsApp</h2>
          <p>Message me, send photos, or voice notes.</p>
          <div class="contact-card-footer">
            <span class="btn btn-secondary contact-btn disabled">Coming Soon</span>
            <span class="contact-note">Great for photos of the problem</span>
          </div>
        </div>

        <div class="contact-card">
          <h2>Email</h2>
          <p>Detailed questions or formal enquiries.</p>
          <div class="contact-card-footer">
            <a href="mailto:hello@061tech.ie?subject=Email%20contact%3A%20061%20Tech" class="btn btn-email contact-btn">Send Email</a>
            <span class="contact-note">For longer queries</span>
          </div>
        </div>

        <div class="contact-card">
          <h2>Video Diagnosis</h2>
          <p>Not sure what's wrong? I'll help figure it out on a video call.</p>
          <div class="contact-card-footer">
            <a href="https://calendly.com/061tech/video-diagnoses" class="btn btn-secondary contact-btn">Book for €10</a>
            <span class="contact-note">15 mins · credited toward repair</span>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Why No Phone -->
  <section class="section section--compact">
    <div class="container why-no-phone">
      <p><strong>Why no phone number?</strong> I focus on fixing computers, not fielding calls. Digital communication means everything is documented, nothing gets lost, and you can reach out anytime - even at 2am. I'll respond within 24 hours.</p>
    </div>
  </section>

  <!-- Contact Form -->
  <section class="section section--alt">
    <div class="container">
      <div class="form-section">
        <h2>Send a Message</h2>
        <p class="form-intro">Have a question that's not about booking a repair? Send me a message.</p>

        <form class="contact-form" id="contact-form" action="https://formspree.io/f/xaqnpewj" method="POST">
          <input type="hidden" name="_subject" id="form-subject-line" value="061Tech: Contact Form">
          <input type="text" name="_gotcha" class="hp-field" tabindex="-1" autocomplete="off">

          <div class="form-row">
            <div class="form-group">
              <label for="name">Name *</label>
              <input type="text" id="name" name="name" required minlength="2" maxlength="100">
            </div>
            <div class="form-group">
              <label for="email">Email *</label>
              <input type="email" id="email" name="email" required maxlength="254">
            </div>
          </div>

          <div class="form-group">
            <label for="subject">Subject *</label>
            <input type="text" id="subject" name="subject" required placeholder="What's this about?" minlength="3" maxlength="80">
            <span class="form-hint">Max 80 characters</span>
          </div>

          <div class="form-group">
            <label for="message">Message *</label>
            <textarea id="message" name="message" required minlength="20" maxlength="2000" placeholder="Your question or message..."></textarea>
            <span class="form-hint">Min 20 characters</span>
          </div>

          <button type="submit" class="btn btn-primary">Send Message</button>
        </form>

        <script>
          const form = document.getElementById('contact-form');
          const subjectInput = document.getElementById('subject');
          const subjectLine = document.getElementById('form-subject-line');

          form.addEventListener('submit', function() {
            const userSubject = subjectInput.value.trim().substring(0, 80);
            subjectLine.value = '061Tech: Contact Form - ' + userSubject;
          });
        </script>
      </div>
    </div>
  </section>

  <!-- Service Area -->
  <section class="section">
    <div class="container service-area">
      <h2>Service Area</h2>
      <p>I serve all of <strong>Limerick city and county</strong> with courier collection and delivery.</p>
      <p>Nearby counties (Clare, Tipperary, Kerry, Cork) may be possible - just ask for a quote on courier costs.</p>
      <p>For remote services (security setup, tune-ups, software), location doesn't matter - I can help anyone in Ireland.</p>
    </div>
  </section>

</Page>

<style>
  /* Page Header */
  .page-header {
    padding: var(--space-2xl) 0 var(--space-xl);
    text-align: center;
  }

  .page-header h1 {
    margin-bottom: var(--space-sm);
  }

  .page-intro {
    font-size: var(--text-lg);
    color: var(--text-secondary);
    max-width: 500px;
    margin: 0 auto;
  }

  /* Contact Grid */
  .contact-grid {
    display: grid;
    gap: var(--space-lg);
    max-width: 700px;
    margin: 0 auto;
  }

  @media (min-width: 640px) {
    .contact-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  /* Why No Phone */
  .section--compact {
    padding: var(--space-md) 0;
  }

  .why-no-phone {
    max-width: 700px;
    text-align: center;
  }

  .why-no-phone p {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    margin: 0;
  }

  .contact-card {
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    padding: var(--space-xl);
    border-radius: 6px;
    text-align: center;
    display: flex;
    flex-direction: column;
  }

  .contact-card h2 {
    font-size: var(--text-lg);
    margin-bottom: var(--space-sm);
  }

  .contact-card p {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    margin-bottom: var(--space-md);
  }

  .contact-card--disabled {
    opacity: 0.6;
  }

  .btn.disabled {
    cursor: not-allowed;
    opacity: 0.7;
  }

  .contact-card-footer {
    margin-top: auto;
  }

  .contact-btn {
    display: block;
    width: 100%;
    text-align: center;
    margin-bottom: var(--space-sm);
  }

  .contact-note {
    display: block;
    font-size: var(--text-sm);
    color: var(--text-muted);
  }

  /* Form Section */
  .form-section {
    max-width: 600px;
    margin: 0 auto;
  }

  .form-section h2 {
    text-align: center;
    margin-bottom: var(--space-sm);
  }

  .form-intro {
    text-align: center;
    color: var(--text-secondary);
    margin-bottom: var(--space-xl);
  }

  .contact-form {
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    padding: var(--space-xl);
    border-radius: 6px;
  }

  .form-group {
    margin-bottom: var(--space-lg);
  }

  .form-row {
    display: grid;
    gap: var(--space-lg);
  }

  @media (min-width: 500px) {
    .form-row {
      grid-template-columns: 1fr 1fr;
    }
  }

  /* Honeypot */
  .hp-field {
    position: absolute;
    left: -9999px;
    opacity: 0;
    height: 0;
    width: 0;
    pointer-events: none;
  }

  /* Service Area */
  .service-area {
    max-width: 600px;
    text-align: center;
  }

  .service-area h2 {
    margin-bottom: var(--space-md);
  }

  .service-area p {
    color: var(--text-secondary);
    margin-bottom: var(--space-sm);
  }
</style>
