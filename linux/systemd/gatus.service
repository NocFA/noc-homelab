[Unit]
Description=Gatus Health Monitoring
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
Environment=GATUS_CONFIG_PATH=/home/noc/noc-homelab/linux/services/gatus/config.yaml
ExecStart=/usr/local/bin/gatus
Restart=on-failure
RestartSec=5
WorkingDirectory=/home/noc/noc-homelab/linux/services/gatus

[Install]
WantedBy=default.target
