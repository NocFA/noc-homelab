#!/usr/bin/env bash
# newrepo — scaffold a new repo with SOPS encryption, beads, GPG signing, and Codeberg remote
# Usage: newrepo <project-name> [--private] [--no-remote]
set -euo pipefail

# ── Config (edit these if your setup changes) ─────────────────────────────────
CODEBERG_USER="noc"
GPG_KEY="BB7B68B7D35F6A68"
AGE_KEYFILE="$HOME/.config/sops/age/keys.txt"
LICENSE_HOLDER="Adam L (noc)"
# CODEBERG_TOKEN: set in env or ~/.config/newrepo/token
# ──────────────────────────────────────────────────────────────────────────────

usage() {
    echo "Usage: newrepo <project-name> [--private] [--no-remote]"
    echo ""
    echo "Creates a new git repo with:"
    echo "  - SOPS + age encryption (encrypt-on-commit)"
    echo "  - Beads (bd) issue tracking"
    echo "  - GPG commit signing"
    echo "  - Codeberg remote"
    echo "  - MIT license"
    echo ""
    echo "Options:"
    echo "  --private     Create a private Codeberg repo (default: public)"
    echo "  --no-remote   Skip Codeberg repo creation"
    echo ""
    echo "Environment:"
    echo "  CODEBERG_TOKEN   API token for Codeberg (or put it in ~/.config/newrepo/token)"
    exit 1
}

# ── Parse args ────────────────────────────────────────────────────────────────
PROJECT=""
PRIVATE=false
NO_REMOTE=false

for arg in "$@"; do
    case "$arg" in
        --private)   PRIVATE=true ;;
        --no-remote) NO_REMOTE=true ;;
        --help|-h)   usage ;;
        -*)          echo "Unknown flag: $arg"; usage ;;
        *)
            if [ -z "$PROJECT" ]; then
                PROJECT="$arg"
            else
                echo "Too many arguments"; usage
            fi
            ;;
    esac
done

[ -z "$PROJECT" ] && usage

# ── Preflight checks ─────────────────────────────────────────────────────────
for cmd in git sops age-keygen bd; do
    if ! command -v "$cmd" >/dev/null 2>&1; then
        echo "Error: $cmd not found. Install it first." >&2
        exit 1
    fi
done

if [ ! -f "$AGE_KEYFILE" ]; then
    echo "Error: age key not found at $AGE_KEYFILE" >&2
    echo "Generate one:  age-keygen -o $AGE_KEYFILE" >&2
    exit 1
fi

AGE_PUBKEY=$(grep 'public key:' "$AGE_KEYFILE" | head -1 | awk '{print $NF}')
if [ -z "$AGE_PUBKEY" ]; then
    echo "Error: could not extract public key from $AGE_KEYFILE" >&2
    exit 1
fi

if [ -d "$PROJECT" ]; then
    echo "Error: directory '$PROJECT' already exists" >&2
    exit 1
fi

# ── Resolve Codeberg token ───────────────────────────────────────────────────
if [ "$NO_REMOTE" = false ]; then
    if [ -z "${CODEBERG_TOKEN:-}" ] && [ -f "$HOME/.config/newrepo/token" ]; then
        CODEBERG_TOKEN=$(cat "$HOME/.config/newrepo/token")
    fi
    if [ -z "${CODEBERG_TOKEN:-}" ]; then
        echo "Warning: no CODEBERG_TOKEN set and no ~/.config/newrepo/token found"
        echo "  Remote repo will be added but NOT created on Codeberg."
        echo "  Create it manually at https://codeberg.org/repo/create"
        echo "  Or set: export CODEBERG_TOKEN=<your-token>"
        echo ""
        CREATE_REMOTE=false
    else
        CREATE_REMOTE=true
    fi
fi

# ── Create repo ──────────────────────────────────────────────────────────────
echo "Creating $PROJECT..."
mkdir -p "$PROJECT"
cd "$PROJECT"

git init -b main --quiet

# ── Git config ────────────────────────────────────────────────────────────────
git config user.signingkey "$GPG_KEY"
git config commit.gpgsign true
git config gpg.program gpg

# ── .gitignore ────────────────────────────────────────────────────────────────
cat > .gitignore << 'EOF'
# SOPS temp files
*.plaintext

# Tooling
.beads/
.gitattributes
AGENTS.md
CLAUDE.md
.claude/

# macOS
.DS_Store
EOF

# ── .gitattributes ────────────────────────────────────────────────────────────
cat > .gitattributes << 'EOF'
# Use bd merge for beads JSONL files
.beads/issues.jsonl merge=beads
EOF

# ── .sops.yaml ────────────────────────────────────────────────────────────────
cat > .sops.yaml << EOF
creation_rules:
  - path_regex: .*\\.sops\\.yaml\$
    age: $AGE_PUBKEY
  - path_regex: .*\\.sops\\.yml\$
    age: $AGE_PUBKEY
  - path_regex: .*\\.env\$
    age: $AGE_PUBKEY
EOF

# ── config.sops.yaml ─────────────────────────────────────────────────────────
cat > config.sops.yaml << 'EOF'
# Sensitive/personal configuration values
# This file is encrypted by SOPS before commit — plaintext at rest, encrypted in git.
placeholder: "replace me"
EOF

# ── LICENSE (MIT) ─────────────────────────────────────────────────────────────
YEAR=$(date +%Y)
cat > LICENSE << EOF
MIT License

Copyright (c) $YEAR $LICENSE_HOLDER

Permission is hereby granted, free of charge, to any person obtaining a copy
of this software and associated documentation files (the "Software"), to deal
in the Software without restriction, including without limitation the rights
to use, copy, modify, merge, publish, distribute, sublicense, and/or sell
copies of the Software, and to permit persons to whom the Software is
furnished to do so, subject to the following conditions:

The above copyright notice and this permission notice shall be included in all
copies or substantial portions of the Software.

THE SOFTWARE IS PROVIDED "AS IS", WITHOUT WARRANTY OF ANY KIND, EXPRESS OR
IMPLIED, INCLUDING BUT NOT LIMITED TO THE WARRANTIES OF MERCHANTABILITY,
FITNESS FOR A PARTICULAR PURPOSE AND NONINFRINGEMENT. IN NO EVENT SHALL THE
AUTHORS OR COPYRIGHT HOLDERS BE LIABLE FOR ANY CLAIM, DAMAGES OR OTHER
LIABILITY, WHETHER IN AN ACTION OF CONTRACT, TORT OR OTHERWISE, ARISING FROM,
OUT OF OR IN CONNECTION WITH THE SOFTWARE OR THE USE OR OTHER DEALINGS IN THE
SOFTWARE.
EOF

# ── README.md ─────────────────────────────────────────────────────────────────
cat > README.md << EOF
# $PROJECT
EOF

# ── AGENTS.md ─────────────────────────────────────────────────────────────────
cat > AGENTS.md << 'EOF'
# Agent Instructions

This project uses **bd** (beads) for issue tracking. Run `bd onboard` to get started.

## Quick Reference

```bash
bd ready              # Find available work
bd show <id>          # View issue details
bd update <id> --status in_progress  # Claim work
bd close <id>         # Complete work
bd sync               # Sync with git
```

## Landing the Plane (Session Completion)

**When ending a work session**, you MUST complete ALL steps below. Work is NOT complete until `git push` succeeds.

**MANDATORY WORKFLOW:**

1. **File issues for remaining work** - Create issues for anything that needs follow-up
2. **Run quality gates** (if code changed) - Tests, linters, builds
3. **Update issue status** - Close finished work, update in-progress items
4. **PUSH TO REMOTE** - This is MANDATORY:
   ```bash
   git pull --rebase
   bd sync
   git push
   git status  # MUST show "up to date with origin"
   ```
5. **Clean up** - Clear stashes, prune remote branches
6. **Verify** - All changes committed AND pushed
7. **Hand off** - Provide context for next session

**CRITICAL RULES:**
- Work is NOT complete until `git push` succeeds
- NEVER stop before pushing - that leaves work stranded locally
- NEVER say "ready to push when you are" - YOU must push
- If push fails, resolve and retry until it succeeds
EOF

# ── Initialize beads ──────────────────────────────────────────────────────────
echo "Initializing beads..."
bd init

# ── Git hooks ─────────────────────────────────────────────────────────────────
# bd init installs its shim hooks; we patch pre-commit and add post-commit for SOPS

cat > .git/hooks/pre-commit << 'HOOK'
#!/usr/bin/env sh
# Pre-commit hook: bd sync + SOPS auto-encryption
# Plaintext at rest, encrypted in git.

# --- bd (beads) hook ---
if command -v bd >/dev/null 2>&1; then
    bd hook pre-commit "$@"
    BD_EXIT=$?
    if [ $BD_EXIT -ne 0 ]; then
        exit $BD_EXIT
    fi
fi

# --- SOPS encryption ---
# Encrypt any staged *.sops.yaml files in-place, re-stage the encrypted version,
# then decrypt back to plaintext so the working tree stays usable.

if ! command -v sops >/dev/null 2>&1; then
    echo "Warning: sops not found, skipping encryption" >&2
    exit 0
fi

# Clear assume-unchanged so we can detect staged sops files
for f in $(git ls-files '*.sops.yaml' '*.sops.yml'); do
    git update-index --no-assume-unchanged "$f" 2>/dev/null
done
if git ls-files --error-unmatch .sops.yaml >/dev/null 2>&1; then
    git update-index --no-assume-unchanged .sops.yaml 2>/dev/null
fi

SOPS_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.sops\.yaml$' || true)

if [ -z "$SOPS_FILES" ]; then
    exit 0
fi

for f in $SOPS_FILES; do
    # Skip if already encrypted (has sops metadata)
    if grep -q "^sops:" "$f" 2>/dev/null; then
        continue
    fi

    echo "SOPS: encrypting $f"

    # Stash plaintext
    cp "$f" "${f}.plaintext"

    # Encrypt in-place and re-stage
    if ! sops -e -i "$f"; then
        echo "Error: SOPS encryption failed for $f" >&2
        mv "${f}.plaintext" "$f"
        exit 1
    fi
    git add "$f"

    # Restore plaintext working copy
    mv "${f}.plaintext" "$f"
done
HOOK

cat > .git/hooks/post-commit << 'HOOK'
#!/usr/bin/env sh
# Post-commit hook: mark SOPS files as assume-unchanged
# so plaintext working copies don't show as modified.

# --- bd (beads) hook ---
if command -v bd >/dev/null 2>&1; then
    bd hook post-commit "$@" 2>/dev/null
fi

# --- SOPS: hide plaintext-vs-ciphertext diff ---
for f in $(git ls-files '*.sops.yaml' '*.sops.yml'); do
    git update-index --assume-unchanged "$f" 2>/dev/null
done

# Also hide .sops.yaml itself (the config gets encrypted too)
if git ls-files --error-unmatch .sops.yaml >/dev/null 2>&1; then
    git update-index --assume-unchanged .sops.yaml 2>/dev/null
fi
HOOK

chmod +x .git/hooks/pre-commit .git/hooks/post-commit

# ── Codeberg remote ──────────────────────────────────────────────────────────
if [ "$NO_REMOTE" = false ]; then
    REMOTE_URL="ssh://git@codeberg.org/${CODEBERG_USER}/${PROJECT}.git"

    if [ "${CREATE_REMOTE:-false}" = true ]; then
        echo "Creating Codeberg repo..."
        HTTP_CODE=$(curl -s -o /dev/null -w "%{http_code}" \
            -X POST "https://codeberg.org/api/v1/user/repos" \
            -H "Authorization: token $CODEBERG_TOKEN" \
            -H "Content-Type: application/json" \
            -d "{\"name\": \"$PROJECT\", \"private\": $PRIVATE, \"default_branch\": \"main\"}")

        if [ "$HTTP_CODE" = "201" ]; then
            echo "  Created: https://codeberg.org/${CODEBERG_USER}/${PROJECT}"
        elif [ "$HTTP_CODE" = "409" ]; then
            echo "  Repo already exists on Codeberg, using it."
        else
            echo "  Warning: Codeberg API returned HTTP $HTTP_CODE"
            echo "  You may need to create the repo manually."
        fi
    fi

    git remote add origin "$REMOTE_URL"
fi

# ── Initial commit ────────────────────────────────────────────────────────────
git add .sops.yaml config.sops.yaml LICENSE README.md .gitignore
git commit -m "Initial commit"

# ── Push ──────────────────────────────────────────────────────────────────────
if [ "$NO_REMOTE" = false ]; then
    echo "Pushing to origin..."
    if git push -u origin main 2>/dev/null; then
        echo "  Pushed."
    else
        echo "  Push failed — create the repo on Codeberg first, then: git push -u origin main"
    fi
fi

# ── Done ──────────────────────────────────────────────────────────────────────
echo ""
echo "Done. $PROJECT is ready."
echo "  cd $PROJECT"
if [ "$NO_REMOTE" = false ]; then
    echo "  https://codeberg.org/${CODEBERG_USER}/${PROJECT}"
fi
